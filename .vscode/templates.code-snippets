		"scope": "c",
		"isFileTemplate": true,
		"body": [
			"/**",
			" * $TM_FILENAME_BASE",
			" * ${1:Description}",
			" *",
			" * @license  \tMIT",
			" * @created  \t$CURRENT_MONTH/$CURRENT_DATE/$CURRENT_YEAR",
			" */",
			"",
			"#ifndef ${TM_FILENAME_BASE}_DEF",
			"#define ${TM_FILENAME_BASE}_DEF",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Included libraries",
			"//-------------------------------------------------------------------------------------",
			"// For int8_t int16_t int32_t int64_t intmax_t uint8_t uint16_t uint32_t uint64_t uintmax_t",
			"#include <stdint.h>",
			"// For NULL",
			"#include <stddef.h>",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Included types",
			"//-------------------------------------------------------------------------------------",
			"#include \"../headers/typeBool.h\"",
			"#include \"../headers/typeType.h\"",
			"#include \"../headers/typeStreamValue.h\"",
			"#include \"../headers/typeStreamDef.h\"",
			"#include \"../headers/typeValueRef.h\"",
			"#include \"../headers/typeRuntimeGlobals.h\"",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Included enums",
			"//-------------------------------------------------------------------------------------",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Included functions",
			"//-------------------------------------------------------------------------------------",
			"#include \"../headers/String.h\"",
			"#include \"../headers/SetStreamError.h\"",
			"#include \"../headers/RuntimeGlobals.h\"",
			"#include \"../headers/StreamValue.h\"",
			"#include \"../headers/StreamDef.h\"",
			"#include \"../headers/StreamType.h\"",
			"#include \"../headers/StringType.h\"",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Stream functions",
			"//-------------------------------------------------------------------------------------",
			"",
			"static void InitStream(typeStreamDef* streamDef) {",
			"",
			"}",
			"",
			"static void CleanupStream(typeStreamDef* streamDef) {",
			"",
			"}",
			"",
			"static void OpenCall(typeStreamValue* stream) {",
			"\tSetStreamError(stream, NULL);",
			"\tstream->opened = true;",
			"}",
			"",
			"static void CloseCall(typeStreamValue* stream) {",
			"\tSetStreamError(stream, NULL);",
			"\tstream->opened = false;",
			"}",
			"",
			"static intmax_t SendCall(typeStreamValue* stream, typeValueRef* data) {",
			"\tSetStreamError(stream, NULL);",
			"",
			"\tif (stream->opened != true) {",
			"\t\tSetStreamError(stream, String(\"You must first open the stream\"));",
			"\t\treturn 0;",
			"\t}",
			"",
			"\treturn 0;",
			"}",
			"",
			"static typeValueRef* FetchCall(typeStreamValue* stream) {",
			"\tSetStreamError(stream, NULL);",
			"",
			"\tif (stream->opened != true) {",
			"\t\tSetStreamError(stream, String(\"You must first open the stream\"));",
			"\t}",
			"",
			"\ttypeRuntimeGlobals* globals = RuntimeGlobals();",
			"\treturn globals->emptyStringRef;",
			"}",
			"",
			"static typeStreamValue* CreateStream(typeStreamDef* streamDef, typeValueRef* params) {",
			"",
			"\treturn StreamValue(",
			"\t\tstreamDef->streamId,",
			"\t\tString(\"%s://\", streamDef->streamId->data),",
			"\t\tparams,",
			"\t\t0,",
			"\t\tstreamDef->streamType,",
			"\t\tNULL,",
			"\t\tOpenCall,",
			"\t\tCloseCall,",
			"\t\tSendCall,",
			"\t\tFetchCall",
			"\t);",
			"}",
			"",
			"typeStreamDef* ${TM_FILENAME_BASE}() {",
			"",
			"\ttypeType* stringType = StringType(false);",
			"\treturn StreamDef(",
			"\t\tInitStream,",
			"\t\tCreateStream,",
			"\t\tCleanupStream,",
			"\t\tString(\"${TM_FILENAME_BASE/(.).*/${1:/downcase}/}${TM_FILENAME_BASE/.(.*)Stream/${1}/}\"),",
			"\t\tStreamType(NULL, stringType, stringType, false),",
			"",
			"\t\t//\t.................................................",
			"\t\tString(",
			"\t\t\t\"${1:Description}\\n\"",
			"\t\t\t\"\\n\"",
			"\t\t\t\"### Open Parameter:\\n\"",
			"\t\t\t\"none\\n\"",
			"\t\t\t\"\\n\"",
			"\t\t\t\"### Input Type:\\n\"",
			"\t\t\t\"```javascript\\n\"",
			"\t\t\t\"any\\n\"",
			"\t\t\t\"```\\n\"",
			"\t\t\t\"\\n\"",
			"\t\t\t\"### Output Type:\\n\"",
			"\t\t\t\"```javascript\\n\"",
			"\t\t\t\"string\\n\"",
			"\t\t\t\"```\\n\"",
			"\t\t\t\"\\n\"",
			"\t\t\t\"### Example\\n\"",
			"\t\t\t\"```javascript\\n\"",
			"\t\t\t\"let handle = open ${TM_FILENAME_BASE/(.).*/${1:/downcase}/}${TM_FILENAME_BASE/.(.*)Stream/${1}/}\\n\"",
			"\t\t\t\"\\n\"",
			"\t\t\t\"// Write a value to the stream\\n\"",
			"\t\t\t\"value -> handle\\n\"",
			"\t\t\t\"\\n\"",
			"\t\t\t\"// Read that value from the stream\\n\"",
			"\t\t\t\"let result = <- handle\\n\"",
			"\t\t\t\"```\\n\"",
			"\t\t\t\"\\n\"",
			"\t\t)",
			"\t);",
			"}",
			"",
			"#endif"
		]
	},

	"Stream Test Template": {
		"prefix": "Stream Test Template",
		"scope": "c",
		"isFileTemplate": true,
		"body": [
			"/**",
			" * ${TM_FILENAME_BASE}",
			" * Unit tests for ${TM_FILENAME_BASE/Test$//}",
			" *",
			" * @license  \tMIT",
			" * @created  \t$CURRENT_MONTH/$CURRENT_DATE/$CURRENT_YEAR",
			" */",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Included libraries",
			"//-------------------------------------------------------------------------------------",
			"// For int8_t int16_t int32_t int64_t intmax_t uint8_t uint16_t uint32_t uint64_t uintmax_t",
			"#include <stdint.h>",
			"// For NULL",
			"#include <stddef.h>",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Included types",
			"//-------------------------------------------------------------------------------------",
			"#include \"../../headers/typeData.h\"",
			"#include \"../../headers/typeStreamDef.h\"",
			"#include \"../../headers/typeStreamValue.h\"",
			"#include \"../../headers/typeValueRef.h\"",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Included enums",
			"//-------------------------------------------------------------------------------------",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Included functions",
			"//-------------------------------------------------------------------------------------",
			"#include \"../../testing/TestTrue.h\"",
			"#include \"../../testing/TestFalse.h\"",
			"#include \"../../testing/TestSame.h\"",
			"#include \"../../testing/TestNotSame.h\"",
			"#include \"../../testing/TestIntsEqual.h\"",
			"#include \"../../testing/TestIntsNotEqual.h\"",
			"#include \"../../testing/TestFloatsEqual.h\"",
			"#include \"../../testing/TestFloatsNotEqual.h\"",
			"#include \"../../testing/TestStringsEqual.h\"",
			"#include \"../../testing/TestStringsNotEqual.h\"",
			"#include \"../../testing/TestNull.h\"",
			"#include \"../../testing/TestNotNull.h\"",
			"",
			"#include \"../../headers/TestMemLeak.h\"",
			"#include \"../../headers/TrackMem.h\"",
			"#include \"../../headers/FreeMem.h\"",
			"#include \"../../headers/String.h\"",
			"#include \"../../headers/EmptyRef.h\"",
			"",
			"#include \"../${TM_FILENAME_BASE/Test$//}.c\"",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Global variables",
			"//-------------------------------------------------------------------------------------",
			"extern typeData* streamsPluginsFolder;",
			"",
			"//-------------------------------------------------------------------------------------",
			"// Test function",
			"//-------------------------------------------------------------------------------------",
			"int32_t main() {",
			"\tTrackMem();",
			"",
			"\t// Don't load any other plugins",
			"\tstreamsPluginsFolder = String(\"tests/noPlugins\");",
			"\tTestMemLeak(streamsPluginsFolder);",
			"",
			"\t// Create the stream",
			"\ttypeStreamDef* streamDef = ${TM_FILENAME_BASE/Test$//}();",
			"\tTestMemLeak(streamDef);",
			"\ttypeStreamValue* stream = streamDef->createFunc(streamDef, NULL);",
			"\tTestMemLeak(stream);",
			"\tTestFalse(stream->opened);",
			"\tTestNull(stream->error);",
			"",
			"\t// Test opening the stream",
			"\tstream->openFunc(stream);",
			"\tTestTrue(stream->opened);",
			"",
			"\t// Test sending data to the stream",
			"\ttypeValueRef* value = EmptyRef();",
			"\tTestMemLeak(value);",
			"\tintmax_t bytes = stream->sendFunc(stream, value);",
			"",
			"\t// Test reading data from the stream",
			"\tvalue = stream->fetchFunc(stream);",
			"\tTestMemLeak(value);",
			"",
			"\t// Test closing the stream",
			"\tstream->closeFunc(stream);",
			"\tTestFalse(stream->opened);",
			"",
			"\tFreeMem();",
			"}",
			""
		]
	}
}
